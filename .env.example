# Server
PORT=3000
APP_URL=                        # URL produksi (contoh: https://api.tbclab.com) — untuk Swagger UI servers

# Database (Supabase / PostgreSQL)
# Use PgBouncer pooler URL for runtime (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Use direct URL for migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Authentication
JWT_SECRET="ganti-dengan-secret-yang-kuat"

# Supabase Storage
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_BUCKET="histopatologi"

# Storage provider (default: supabase)
STORAGE_PROVIDER="supabase"

# CORS — pisahkan beberapa origin dengan koma
CORS_ORIGIN="http://localhost:5173"
